# Copy to .env.local and fill with values from your SAM/CloudFormation outputs.
# All NEXT_PUBLIC_* vars are inlined into the client bundle at build time.

# Cognito User Pool ID (e.g. us-east-1_xxxxxxxxx). Amplify v6 infiere la región
# de este mismo ID, por eso no se necesita una variable de región aparte.
NEXT_PUBLIC_USER_POOL_ID=

# Cognito User Pool App Client ID (public SPA client, no secret).
NEXT_PUBLIC_USER_POOL_CLIENT_ID=

# Base URL of the read-only PanelApi (from SAM outputs), no trailing slash.
# El stage es $default, así que la URL NO lleva segmento de stage:
# e.g. https://abc123.execute-api.us-east-1.amazonaws.com
NEXT_PUBLIC_API_BASE_URL=
